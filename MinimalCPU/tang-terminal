#!/bin/bash
# tang-terminal - Command-Line Hardware Toolchain Synthesis Automations
# Optimized for your nextpnr-himbaechel + Apicula environment

BUILD_DIR="."
FILENAME="yesco_terminal"

# 1. Clean previous build files
rm -f "${BUILD_DIR}/${FILENAME}.json" "${BUILD_DIR}/${FILENAME}_pnr.json" "${BUILD_DIR}/${FILENAME}.fs"

echo ">>> Phase 1: Synthesizing Hardware Register Logic with Yosys..."
yosys -p "
    synth_gowin -top top_terminal -json ${BUILD_DIR}/${FILENAME}.json
" \
top_terminal.v \
mock_cpu.v \
font_rom_8x16.v \
uart/uart_rx.v \
uart/uart_tx.v \
dvi_tx.v \
video_sync.v \
gowin_rpll/gowin_rpll.v || exit 1

echo ">>> Phase 2: Running Physical Place & Route Routing Core using Himbaechel..."
nextpnr-himbaechel \
    -v \
    --device GW2AR-LV18QN88C8/I7 \
    --vopt family=GW2A-18C \
    --vopt cst="terminal.cst" \
    --json "${BUILD_DIR}/${FILENAME}.json" \
    --write "${BUILD_DIR}/${FILENAME}_pnr.json" || exit 1

echo ">>> Phase 3: Packing Final Configuration Memory Bitstream Image..."
gowin_pack \
    -d GW2A-18C \
    -o "${BUILD_DIR}/${FILENAME}.fs" \
    "${BUILD_DIR}/${FILENAME}_pnr.json" || exit 1

echo "================================================================="
echo " SUCCESS: Gowin stream located at ${BUILD_DIR}/${FILENAME}.fs"
echo "================================================================="
