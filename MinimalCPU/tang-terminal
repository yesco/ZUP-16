#!/bin/bash
# tang-terminal - Command-Line Hardware Toolchain Synthesis Automations

# 1. Force a clean directory state
rm -f terminal_gates.json terminal_routed.json yesco_terminal.fs

echo ">>> Phase 1: Synthesizing Hardware Register Logic with Yosys..."
yosys -p "
    synth_gowin -top top_terminal -json terminal_gates.json
" \
top_terminal.v \
mock_cpu.v \
vga_font_16.hexv \
uart/uart_rx.v \
uart/uart_tx.v \
dvi_tx/dvi_tx.v \
gowin_rpll/gowin_rpll.v || exit 1

echo ">>> Phase 2: Running Physical Place & Route Routing Core..."
# Fixed: Mapped explicitly to your local 'terminal.cst' file name
nextpnr-gowin \
    --json terminal_gates.json \
    --write terminal_routed.json \
    --device GW2AR-LV18QN88C8/I7 \
    --cst terminal.cst || exit 1

echo ">>> Phase 3: Packing Final Configuration Memory Bitstream Image..."
gowin_pack \
    -d GW2AR-LV18QN88C8/I7 \
    -o yesco_terminal.fs \
    terminal_routed.json || exit 1

echo "================================================================="
echo " SUCCESS: Hardware binary generated as 'yesco_terminal.fs'"
echo "================================================================="
