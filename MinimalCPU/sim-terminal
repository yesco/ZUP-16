#!/bin/bash
TARGET=$1
if [ -z "$TARGET" ]; then
    echo "Usage: ./sim-terminal <top_module_name>"
    exit 1
fi

rm -f ${TARGET}.sim

# Compile files with high-level system standard parsing
iverilog -g2012 -DSIMULATION -o ${TARGET}.sim \
    top_terminal.v \
    mock_cpu.v \
    terminal-mocks.v \
    ${TARGET}_tb.v || exit

# Save original terminal configurations
OLD_STTY=$(stty -g)

# Force the Unix terminal window into single-character instant raw execution mode
stty raw -echo

# Fire execution wrapper explicitly mapping standard input descriptors directly down to vvp
vvp ${TARGET}.sim -vcd

# Restore your normal command line settings cleanly
stty "$OLD_STTY"
echo ""
echo "--- DONE ---"
