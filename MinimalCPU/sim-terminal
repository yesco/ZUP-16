#!/bin/bash
TARGET=$1
if [ -z "$TARGET" ]; then
    echo "Usage: ./sim-terminal <top_module_name>"
    exit 1
fi

rm -f ${TARGET}.sim

# Force clean modern verilog parser standards
# We drop the hardware cell library entirely for the mock test run to break the deadlock
iverilog -g2012 -DSIMULATION -o ${TARGET}.sim \
    top_terminal.v \
    mock_cpu.v \
    terminal-mocks.v \
    uart/uart_rx.v \
    uart/uart_tx.v \
    ${TARGET}_tb.v || exit

# Run the execution wrapper with runtime event step throttling
vvp ${TARGET}.sim | tee ${TARGET}.out || exit

git diff -U9999 ${TARGET}.out
echo "--- DONE ---"
