#!/bin/bash
TARGET=$1
if [ -z "$TARGET" ]; then
    echo "Usage: ./sim-terminal <top_module_name>"
    exit 1
fi

# Clean up any leftover artifacts from previous runs
rm -f ${TARGET}.sim terminal_pipe
killall -9 vvp 2>/dev/null

# Create a true Unix named pipe (FIFO) file pipeline
mkfifo terminal_pipe

# Compile project assets cleanly with system parsing parameters
iverilog -g2012 -DSIMULATION -o ${TARGET}.sim \
    top_terminal.v \
    mock_cpu.v \
    terminal-mocks.v \
    ${TARGET}_tb.v || exit

# Save original terminal configurations
OLD_STTY=$(stty -g)

# Force the Unix terminal window into single-character instant raw execution mode
stty raw -echo

# Route standard keyboard input descriptors straight into the background pipe channel
dd bs=1 if=/dev/stdin of=terminal_pipe 2>/dev/null &
DD_PID=$!

# Execute the simulation engine in the foreground
vvp ${TARGET}.sim

# Cleanup: Kill background processes, restore terminal state, and delete the pipe file
kill $DD_PID 2>/dev/null
stty "$OLD_STTY"
rm -f terminal_pipe
echo ""
echo "--- DONE ---"
