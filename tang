#!/bin/bash -xe

if [ -z "$1" ]; then
    echo "Usage: $0 <project_name> [top_module]"
    echo "  <project_name>  Mandatory. Base name of your .v file."
    echo "  [top_module]    Optional. Overrides top module name."
    exit 1
fi

FILENAME=$1
TOP_MODULE=$2
BUILD_DIR="build"

mkdir -p "$BUILD_DIR"

# 1. Run Yosys Synthesis targeting Gowin architecture
if [ -n "$TOP_MODULE" ]; then
    YOSYS_CMD="synth_gowin -top ${TOP_MODULE} -json ${BUILD_DIR}/${FILENAME}.json"
else
    YOSYS_CMD="synth_gowin -json ${BUILD_DIR}/${FILENAME}.json"
fi

yosys -p "$YOSYS_CMD" "${FILENAME}.v"

# 2. Inject the Exact Physical Pins for the Sipeed Tang Nano 20K QN88 Pack
DUMMY_CST="${BUILD_DIR}/dummy_ports.cst"

printf '%s\n' \
    "IO_LOC \"clk\" 4;" \
    "IO_LOC \"rst_n\" 88;" \
    "IO_LOC \"pins_out[0]\" 73;" \
    "IO_LOC \"pins_out[1]\" 74;" \
    "IO_LOC \"pins_out[2]\" 75;" \
    "IO_LOC \"pins_out[3]\" 76;" \
    "IO_LOC \"pins_out[4]\" 77;" \
    "IO_LOC \"leds_out[0]\" 15;" \
    "IO_LOC \"leds_out[1]\" 16;" \
    "IO_LOC \"leds_out[2]\" 17;" \
    > "$DUMMY_CST"

# 3. Place & Route using himbaechel with your complete constraint file
nextpnr-himbaechel \
    -v \
    --device GW2AR-LV18QN88C8/I7 \
    --vopt family=GW2A-18C \
    --vopt cst="$DUMMY_CST" \
    --json "${BUILD_DIR}/${FILENAME}.json" \
    --write "${BUILD_DIR}/${FILENAME}_pnr.json"

# 4. Bitstream Generation using Project Apicula
gowin_pack -d GW2A-18C -o "${BUILD_DIR}/${FILENAME}.fs" "${BUILD_DIR}/${FILENAME}_pnr.json"

echo "Success! Gowin stream located at ${BUILD_DIR}/${FILENAME}.fs"
